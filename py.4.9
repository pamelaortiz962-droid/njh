import random
import time

numeros = []

for i in range(5):
    numeros.append(random.choice([1,2,3,4,5,6,7,8,9]))

print("Memoriza estos números:")
print(numeros)

time.sleep(3)

print("\n" * 20)

entrada = input("Números: ")
lista = entrada.split(",")

correcto = True

for i in range(5):
    if int(lista[i]) != numeros[i]:
        correcto = False

if correcto:
    print("¡Ganaste!")
else:
    print("Perdiste")
