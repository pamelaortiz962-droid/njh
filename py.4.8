
import random
import time

numeros = []

for i in range(5):
    numero = random.randint(1, 9)
    numeros.append(numero)

print("Memoriza estos números:")
print(numeros)

time.sleep(3)

print("\n" * 20)

print("Ingresa los números en el mismo orden:")

correcto = True

for i in range(5):
    respuesta = int(input("Número: "))
    
    if respuesta != numeros[i]:
        correcto = False

if correcto:
    print("¡Ganaste :D!")
else:
    print("Perdiste xd")
